# Local dev environment variables for the Jaffle Shop dbt project.
#
# The default `dev` target (DuckDB) needs none of this -- `make build` /
# `task build` work with no .env file at all. This is only needed to test
# the `prod` target (Athena) from your laptop, against infra already
# deployed via `infra/` (see INFRA.md).
#
# Copy to .env (gitignored, never commit real values) and fill in the
# DBT_ATHENA_* values from:
#   aws cloudformation describe-stacks --stack-name JaffleShopStack \
#     --query "Stacks[0].Outputs" --output table

# Uncomment to run against Athena instead of the local DuckDB file:
# DBT_TARGET=prod

AWS_REGION=us-east-1
DBT_ATHENA_BUCKET=
DBT_ATHENA_SCHEMA=jaffle_shop
DBT_ATHENA_WORKGROUP=primary

# Optional: select a specific AWS CLI/SSO profile instead of the default
# credential chain. Your local identity needs Athena/Glue/S3 permissions
# equivalent to DbtTaskRole in infra/jaffle_shop_infra/stack.py -- you
# don't get the Fargate task's IAM role for free locally.
# AWS_PROFILE=
